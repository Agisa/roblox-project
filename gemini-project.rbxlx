				<Item class="Script" referent="RBX5B80477C04554431938C8690FCFD6C00">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local TweenService = game:GetService("TweenService")
local sensor = script.Parent
local doorLeft = sensor.Parent:WaitForChild("Vrata_Levo")
local doorRight = sensor.Parent:WaitForChild("Vrata_Desno")

-- Zatvorene pozicije (trenutne)
local leftClose = doorLeft.Position
local rightClose = doorRight.Position

-- Otvorene pozicije (vrata se razmiču u stranu za po 8 stud-ova)
local leftOpen = leftClose + Vector3.new(-8, 0, 0) 
local rightOpen = rightClose + Vector3.new(8, 0, 0)

-- Podešavanje brzine i glatkoće otvaranja (traje 0.6 sekundi)
local info = TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local openLeft = TweenService:Create(doorLeft, info, {Position = leftOpen})
local closeLeft = TweenService:Create(doorLeft, info, {Position = leftClose})
local openRight = TweenService:Create(doorRight, info, {Position = rightOpen})
local closeRight = TweenService:Create(doorRight, info, {Position = rightClose})

local doorOpen = false

-- Petlja koja na svakih 0.2 sekunde proverava da li ima nekoga blizu
while true do
	task.wait(0.2)
	local foundSomeone = false

	-- Provera svih karaktera u igri (igrači i NPC-jevi)
	for _, obj in pairs(workspace:GetChildren()) do
		local humanoid = obj:FindFirstChildOfClass("Humanoid")
		local rootPart = obj:FindFirstChild("HumanoidRootPart")
		if humanoid and rootPart then
			-- Izračunavanje udaljenosti između karaktera i senzora
			local distance = (rootPart.Position - sensor.Position).Magnitude
			if distance < 10 then -- Detektuje na udaljenosti od 10 stud-ova
				foundSomeone = true
				break
			end
		end
	end

	-- Pokretanje animacije otvaranja/zatvaranja
	if foundSomeone and not doorOpen then
		doorOpen = true
		openLeft:Play()
		openRight:Play()
	elseif not foundSomeone and doorOpen then
		doorOpen = false
		closeLeft:Play()
		closeRight:Play()
	end
end]]></ProtectedString>
